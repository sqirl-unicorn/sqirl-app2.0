{
  "expo": {
    "name": "Sqirl",
    "slug": "sqirl",
    "version": "1.0.0",
    "scheme": "sqirl",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.sqirl.app" },
    "android": { "package": "com.sqirl.app", "adaptiveIcon": { "backgroundColor": "#60a5fa" } },
    "plugins": ["expo-router", "expo-sqlite"],
    "experiments": { "typedRoutes": true }
  }
}
